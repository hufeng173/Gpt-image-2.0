generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         String     @id @default(cuid())
  email      String     @unique
  name       String?
  role       UserRole   @default(USER)
  dailyQuota Int        @default(20)
  createdAt  DateTime   @default(now())
  jobs       ImageJob[]
  images     Image[]
}

model ImageJob {
  id           String    @id @default(cuid())
  accessCodeId String?
  accessCode   AccessCode? @relation(fields: [accessCodeId], references: [id])
  userId       String?
  user         User?     @relation(fields: [userId], references: [id])
  provider     String    @default("relay")
  model        String
  prompt       String    @db.Text
  negative     String?   @db.Text
  size         String    @default("1024x1024")
  count        Int       @default(1)
  status       JobStatus @default(PENDING)
  errorMessage String?   @db.Text
  rawResponse  Json?
  createdAt    DateTime  @default(now())
  finishedAt   DateTime?
  images       Image[]

  @@index([accessCodeId])
}

model Image {
  id        String   @id @default(cuid())
  jobId     String
  job       ImageJob @relation(fields: [jobId], references: [id])
  accessCodeId String?
  accessCode   AccessCode? @relation(fields: [accessCodeId], references: [id])
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  url       String   @db.Text
  width     Int?
  height    Int?
  seed      String?
  createdAt DateTime @default(now())

  @@index([accessCodeId])
}

model AccessCode {
  id           String               @id @default(cuid())
  label        String
  codeHash     String               @unique
  displayCode  String?
  role         AccessRole           @default(USER)
  createdAt    DateTime             @default(now())
  lastUsedAt   DateTime?
  conversations SavedConversation[]
  attachments   Attachment[]
  imageJobs     ImageJob[]
  images        Image[]
}

model SavedConversation {
  id           String     @id
  accessCodeId String
  accessCode   AccessCode @relation(fields: [accessCodeId], references: [id])
  title        String
  messages     Json
  createdAt    DateTime
  updatedAt    DateTime
  attachments  Attachment[]

  @@index([accessCodeId])
  @@index([updatedAt])
}

model Attachment {
  id             String             @id @default(cuid())
  accessCodeId   String
  accessCode     AccessCode         @relation(fields: [accessCodeId], references: [id])
  conversationId String?
  conversation   SavedConversation? @relation(fields: [conversationId], references: [id])
  messageId      String?
  name           String
  mimeType       String
  size           Int
  kind           AttachmentKind
  status         AttachmentStatus   @default(READY)
  url            String?            @db.Text
  storagePath    String             @db.Text
  summary        String?            @db.Text
  materials      Json?
  warnings       Json?
  createdAt      DateTime           @default(now())

  @@index([accessCodeId])
  @@index([conversationId])
  @@index([kind])
  @@index([createdAt])
}

enum UserRole {
  USER
  ADMIN
}

enum AccessRole {
  USER
  ADMIN
}

enum JobStatus {
  PENDING
  RUNNING
  SUCCEEDED
  PARTIAL_SUCCEEDED
  FAILED
}

enum AttachmentKind {
  IMAGE
  DOCUMENT
  SPREADSHEET
  TEXT
  OTHER
}

enum AttachmentStatus {
  PROCESSING
  READY
  FAILED
}
